# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://musicsystem:musicsystem_secret@localhost:5432/musicsystem?schema=public"

# ── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ───────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRY="7d"

# ── File Storage ───────────────────────────────────────────
UPLOADS_DIR="./uploads"
MAX_FILE_SIZE_MB=50

# ── CORS ───────────────────────────────────────────────────
CLIENT_URL="http://localhost:3000"
